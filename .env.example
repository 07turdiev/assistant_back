DJANGO_SETTINGS_MODULE=assistant.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend domeni — Telegram bot xabarlari va email link'larida ishlatiladi.
# Protokol (https://) bilan, oxirida slash bo'lmasin.
FRONTEND_BASE_URL=https://assistant.madaniyhayot.uz

DATABASE_URL=sqlite:///db.sqlite3

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

COOKIE_DOMAIN=
COOKIE_SECURE=False
COOKIE_SAMESITE=Lax

JWT_ACCESS_LIFETIME_SECONDS=86400
JWT_REFRESH_LIFETIME_SECONDS=604800

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@madaniyat.uz

# AI / Ollama (lokal LLM server)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# STT — UzbekVoice.ai (https://uzbekvoice.ai)
UZBEKVOICE_API_KEY=
UZBEKVOICE_LANGUAGE=uz
UZBEKVOICE_MODEL=general

# Ovoz fayllar saqlash muddati (kun)
VOICE_FILE_RETENTION_DAYS=30
